menu "Zephyr Kernel"
    source "Kconfig.zephyr"
endmenu

menu "ZSPSUMon"

    config PICO_DISPLAY_PACK
        bool
    prompt "Pico Display Pack"
    default n

    config PICO_DISPLAY_PACK2
        bool
    prompt "Pico Display Pack2"
    default n

    config APP_FLUSH_BENCH
        bool "Display SPI flush benchmark"
        default n
        select THREAD_RUNTIME_STATS
        help
          One-shot benchmark at boot that times display_write() and reports
          CPU left free during flushes from the scheduler's idle accounting
          (THREAD_RUNTIME_STATS). Prints a FLUSH BENCH block over printk.
          Off by default; enable to re-measure the SPI path.

    config DISPLAY_SPI_PIO_DMA
        bool "Drive the display SPI via PIO + TX-DMA (experimental)"
        default n
        select PINCTRL
        select PICOSDK_USE_PIO
        select PICOSDK_USE_CLAIM
        select PICOSDK_USE_DMA
        help
          Replace the PL022 hardware-SPI path with an in-project PIO state
          machine fed by a single TX DMA channel. Frees the CPU during flush
          and exposes a tunable clock/gap. When off, the display uses the
          default PL022 + DMA path.

    config APP_WIFI_AP
        bool "Pico W: WiFi AP mode + UDP PSU control"
        default n
        help
          Opt-in (set by ap.conf): run the Pico W as a WiFi Access Point and
          expose a small UDP text protocol on :5000 that drives the PSU. Selects
          the AP glue (src/net/wifi_ap.c) and the UDP server (src/net/psu_udp.c),
          and excludes the STA glue (src/net/wifi_net.c). Mutually exclusive with
          the STA wifi.conf build. Default builds are unaffected.

    config APP_WIFI_AP_AUTOSTART
        bool "Bring the SoftAP up automatically at boot"
        depends on APP_WIFI_AP
        default y
        help
          When set, src/net/wifi_ap.c starts the SoftAP from a boot-time work
          item. Turn OFF (-DCONFIG_APP_WIFI_AP_AUTOSTART=n) to leave the AP down
          at boot and bring it up manually from the shell
          (wifi ap enable -s <ssid> -k 1 -p <psk> -c 6) — used to isolate the
          driver's AP path from the boot-time auto-bringup during debugging.

    config APP_USB_DFU
        bool "Software-triggered USB firmware upgrade (reset to BOOTSEL)"
        default n
        help
          Opt-in (set by dfu.conf): compile the src/dfu/ trigger module. A
          shell `dfu` / UDP `DFU` / A+Y button-hold calls dfu_enter_recovery(),
          which uses the RP2040 bootrom reset_usb_boot() to drop the device
          into the USB mask-ROM bootloader (BOOTSEL) — a software-triggered,
          button-free firmware upgrade (drag a .uf2 / picotool load). No
          MCUboot, no repartition, no signing. Default builds are unaffected.

endmenu
